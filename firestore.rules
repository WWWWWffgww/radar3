cd ~/radar3

cat > firestore.rules <<'RULES'
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function role() {
      return signedIn() && request.auth.token.role != null
        ? request.auth.token.role
        : "user";
    }

    function isMod() {
      return role() == "moderator" || role() == "admin" || role() == "superadmin";
    }

    function isAdmin() {
      return role() == "admin" || role() == "superadmin";
    }

    function isSuper() {
      return role() == "superadmin";
    }

    match /users/{uid} {
      allow read: if signedIn() && (uid == request.auth.uid || isAdmin());
      allow write: if isSuper();
    }

    match /points/{pointId} {
      allow read: if resource.data.hidden != true || isMod();
      allow create: if signedIn();
      allow update: if signedIn();
      allow delete: if isAdmin();
    }

    match /app_config/{docId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /sanctions/{sanctionId} {
      allow read, write: if isAdmin();
    }

    match /audit_log/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }
  }
}
RULES

npx firebase deploy --only firestore:rules,functions
