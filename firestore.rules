cd ~/radar3

cat > firestore.rules <<'RULES'
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function role() {
      return signedIn() && request.auth.token.role != null
        ? request.auth.token.role
        : "user";
    }

    function roleRank(r) {
      return r == "superadmin" ? 3
        : r == "admin" ? 2
        : r == "moderator" ? 1
        : 0;
    }

    function atLeast(r) {
      return roleRank(role()) >= roleRank(r);
    }

    function isMod() { return atLeast("moderator"); }
    function isAdmin() { return atLeast("admin"); }
    function isSuper() { return atLeast("superadmin"); }

    function emergencyEnabled() {
      return exists(/databases/$(database)/documents/app_config/global) &&
             get(/databases/$(database)/documents/app_config/global).data.emergencyMode == true;
    }

    function isSanctioned() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.sanction.expiresAt is timestamp &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.sanction.expiresAt > request.time;
    }

    function canWriteAsUser() {
      return signedIn() && !emergencyEnabled() && !isSanctioned();
    }

    match /users/{uid} {
      allow read: if signedIn() && (uid == request.auth.uid || isAdmin());
      allow write: if isSuper();
    }

    match /points/{pointId} {
      allow read: if resource.data.hidden != true || isMod();
      allow create: if canWriteAsUser();
      allow update: if isMod() || canWriteAsUser();
      allow delete: if isAdmin();
    }

    match /app_config/{docId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /sanctions/{sanctionId} {
      allow read: if isAdmin() || (signedIn() && sanctionId == ("uid_" + request.auth.uid));
      allow write: if isAdmin();
    }

    match /audit_log/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }
  }
}
RULES

npx firebase deploy --only functions,firestore:rules
